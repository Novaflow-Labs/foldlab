# Copy to backend/.env and fill in keys. NEVER commit real keys.
# Keys are read SERVER-SIDE only and never sent to the browser.

ROWAN_API_KEY=
ANTHROPIC_API_KEY=

# Folding provider: "mock" (deterministic, zero-cost, default) or "rowan" (real folding)
FOLDING_PROVIDER=mock

ANTHROPIC_MODEL=claude-opus-4-8
DEFAULT_FOLD_MODEL=boltz_2
DB_URL=sqlite:///./protein_demo.db
STRUCTURE_DIR=./app/data/structures

# Per-job Rowan credit cap (optional safety limit). Uncomment to enable.
# MAX_CREDITS=50

# JSON array of allowed origins for a deployed frontend. Dev uses the Vite proxy (no CORS).
CORS_ORIGINS=["http://localhost:5173"]
